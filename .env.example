# Copy to .env and fill in. .env is gitignored.
VOYAGE_API_KEY=

# Generation: the OpenAI-compatible adapter reads this as the OpenAI api_key against
# the OpenRouter base URL (set GEN_PROVIDER=openai-compat to use it).
OPENROUTER_API_KEY=

# Web search tool for the agent loop (rag/query/web_search_agent.py).
TAVILY_API_KEY=

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# Deep agent / guardrails (Anthropic native path).
ANTHROPIC_API_KEY=

# Postgres. Defaults to postgresql://postgres:postgres@localhost:5432/rag if unset.
DATABASE_URL=